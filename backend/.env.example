# Copy to backend/.env and fill in. backend/.env is git-ignored.

# Neon Postgres pooled connection string
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS allow-list, comma-separated
ALLOWED_ORIGINS=http://localhost:5173,https://www.ryanpp.com,https://ryanpp.com
